{
  "name": "@valotas/valotas-frontend",
  "version": "3.12.0",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/valotas/valotas.com.git"
  },
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist node_modules",
    "lint": "eslint \"src/**/*.+(ts|js|tsx|jsx)\"",
    "fix": "npm run lint -- --fix",
    "build": "tsc -p .",
    "watch:build": "tsc -p . -w",
    "test": "cross-env NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --no-cache",
    "watch:test": "jest --watch",
    "preversion": "npm run lint && npm run build && npm run test",
    "v": "tsc --version"
  },
  "dependencies": {
    "@testing-library/preact": "^3.2.4",
    "@types/marked": "^4.0.2",
    "@types/node-fetch": "^2.6.1",
    "@types/prismjs": "^1.26.0",
    "cross-env": "^7.0.3",
    "date-fns": "^2.28.0",
    "markdown-to-jsx": "^7.4.7",
    "moment": "^2.29.1",
    "preact": "^10.22.0",
    "preact-render-to-string": "^6.5.5",
    "prismjs": "^1.29.0",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "babel-loader": "^8.2.3"
  }
}
